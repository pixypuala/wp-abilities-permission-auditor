{
    "name": "pixypuala/wp-abilities-permission-auditor",
    "description": "Audits WordPress role/capability assignments for privilege-escalation risks and over-broad grants, with deterministic exit codes for CI.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "bin": ["bin/wp-abilities-auditor"],
    "require": {
        "php": ">=8.1",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Pixypuala\\AbilitiesAuditor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pixypuala\\AbilitiesAuditor\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "lint:fix": "phpcbf"
    }
}
